{
  "$schema": "https://raw.githubusercontent.com/nicegui-org/nicegui/main/.vscode/tauri.schema.json",
  "productName": "AgentRoom",
  "version": "0.1.0",
  "identifier": "com.agentroom.visual",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "title": "AgentRoom",
        "width": 1200,
        "height": 800,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  }
}
